# ========================================================================================
# .ENV EXAMPLE — Скопируйте в .env и заполните реальные значения
# ========================================================================================

# ⭐ КРИТИЧНО: OpenAI API для LLM валидации телефонов (phone_final_validator.py) 
# Получить на: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⭐ КРИТИЧНО: Модель OpenAI для LLM валидации
# Рекомендуется: gpt-4o-mini (очень дешевая, ~$0.15 за 1M input токенов)
# Альтернативы: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Опционально: контролировать использование LLM
# Если false — используется только phonenumbers без LLM
USE_LLM_VALIDATION=true

# ========================================================================================
# Опционально: Другие переменные (если используются)
# ========================================================================================

# Если нужно логировать в файл
LOG_FILE=logs/extract.log
LOG_LEVEL=INFO

# Timeout для Crawl4AI
CRAWL_TIMEOUT=30

# Max pages to crawl
MAX_PAGES=25

# ========================================================================================
# ДЛЯ РАЗРАБОТЧИКОВ
# ========================================================================================

# Debug mode
DEBUG=false

# ========================================================================================
# ВАЖНО!
# ========================================================================================
# 1. НЕ коммитьте .env в git! Используйте .env.example как template
# 2. Проверьте .gitignore:
#    .env
#    .env.local
#    *.key
# 3. Для разработки: cp .env.example .env && vim .env
# ========================================================================================
