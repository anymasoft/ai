# Cross-platform npm configuration for Windows compatibility
# Кроссплатформенная конфигурация для совместимости с Windows

# Allow peer dependencies that would normally cause warnings
legacy-peer-deps=true

# Treat warnings as non-fatal
engine-strict=false

# Configure script shell for Windows
# Let npm use the default shell (cmd.exe on Windows, bash on Unix)
# script-shell is set per-platform by the build scripts

# Log level for debugging
loglevel=warn
